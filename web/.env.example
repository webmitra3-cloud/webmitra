NODE_ENV=development
PORT=3000

# Database
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Frontend URL (must match deployed web domain in production)
CLIENT_ORIGIN=http://localhost:3000

# Optional: set only if you need cookie sharing across subdomains
# COOKIE_DOMAIN=.webmitra.tech
COOKIE_DOMAIN=

# JWT (use long random strings in production)
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=wm_refresh
CSRF_COOKIE_NAME=wm_csrf

# Password hashing
BCRYPT_ROUNDS=12

# Seed admin user
ADMIN_SEED_EMAIL=admin@webmitra.tech
ADMIN_SEED_PASSWORD=replace-with-strong-admin-password

# Resend (required for contact form transactional email)
# Replace re_xxxxxxxxx with your real Resend API key.
RESEND_API_KEY=re_xxxxxxxxx
MAIL_FROM=WebMitra.Tech <hello@webmitra.tech>
MAIL_TO=webmitra3@gmail.com
AUTO_REPLY_ENABLED=true

# Startup seeding (production)
# true: insert demo content only when collections are empty, and sync admin credentials from env
SEED_DUMMY_ON_STARTUP=true

# Cloudinary (required for image uploads)
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# Company WhatsApp number used in seeded/default data
WHATSAPP_NUMBER=9779869672736

NEXT_PUBLIC_WHATSAPP_NUMBER=9779869672736
